{
  "name": "aktivitetsplan",
  "version": "2.0.0",
  "description": "Aktivitetsplan",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:gh-pages": "VITE_USE_HASH_ROUTER=true vite",
    "build:dev-ekstern": "vite build --mode=dev-ekstern --base=https://cdn.nav.no/dab/aktivitetsplan-dev-ekstern/build/",
    "build:dev-intern": "vite build --mode=dev-intern --base=https://cdn.nav.no/dab/aktivitetsplan-dev-intern/build/",
    "build:prod-ekstern": "vite build --mode=prod-ekstern --base=https://cdn.nav.no/dab/aktivitetsplan-prod-ekstern/build/",
    "build:prod-intern": "vite build --mode=prod-intern --base=https://cdn.nav.no/dab/aktivitetsplan-prod-intern/build/",
    "build": "cross-env VITE_USE_HASH_ROUTER=true vite build --mode=dev",
    "build:gh-pages": "VITE_USE_HASH_ROUTER=true vite build --mode=dev-ekstern --base=/aktivitetsplan/",
    "test": "NODE_OPTIONS=--no-webstorage vitest",
    "coverage": "NODE_OPTIONS=--no-webstorage vitest run --coverage",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "format-all": "prettier --write 'src/'",
    "lint-staged": "lint-staged",
    "analyze": "source-map-explorer 'build/static/js/*.js'",
    "preview": "vite preview"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@navikt/aksel-icons": "^8.14.0",
    "@navikt/dab-spraksjekk": "^1.0.20",
    "@navikt/ds-css": "^8.14.0",
    "@navikt/ds-react": "^8.14.0",
    "@navikt/ds-tailwind": "^8.14.0",
    "@navikt/nav-dekoratoren-moduler": "^3.6.1",
    "@reduxjs/toolkit": "^2.12.0",
    "@sentry/react": "^8.55.2",
    "@vitejs/plugin-react": "^6.0.3",
    "classnames": "^2.5.1",
    "date-fns": "^4.4.0",
    "pdfjs-dist": "^5.7.284",
    "prop-types": "^15.8.1",
    "react": "^19.2.7",
    "react-collapse": "^5.1.1",
    "react-custom-scrollbars-2": "^4.5.0",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.81.0",
    "react-modal": "^3.16.3",
    "react-pdf": "^10.4.1",
    "react-redux": "^9.3.0",
    "react-router": "^7.18.1",
    "rebound": "^0.1.0",
    "redux": "^5.0.1",
    "source-map-explorer": "^2.5.3",
    "typescript": "^5.9.3",
    "vite": "^8.1.3",
    "vite-plugin-svgr": "^4.5.0",
    "vitest": "^4.1.10",
    "zod": "^3.25.76"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{js,ts,tsx,json,less,css,md}": [
      "prettier --write"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not ie <= 10",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.43",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/moment-duration-format": "^2.2.7",
    "@types/node": "^22.20.1",
    "@types/react": "^19.2.17",
    "@types/react-collapse": "^5.0.4",
    "@types/react-dom": "^19.1.0",
    "@types/react-modal": "^3.16.3",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "@vitest/coverage-v8": "^4.1.10",
    "autoprefixer": "^10.5.2",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-vitest": "^0.5.4",
    "husky": "^9.1.7",
    "import-sort-style-module": "^6.0.0",
    "jsdom": "^28.1.0",
    "less": "^4.6.7",
    "lint-staged": "^15.5.2",
    "msw": "^2.15.0",
    "postcss": "8.5.14",
    "prettier": "^3.9.4",
    "prettier-plugin-import-sort": "0.0.7",
    "tailwindcss": "^4.3.2",
    "vite-plugin-static-copy": "^4.1.1",
    "vite-plugin-tailwind-shadowdom": "^1.1.1"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/navikt/aktivitetsplan.git"
  },
  "importSort": {
    ".js, .jsx, .ts, .tsx": {
      "style": "module",
      "parser": "typescript"
    }
  },
  "msw": {
    "workerDirectory": "public"
  },
  "packageManager": "pnpm@11.13.0+sha512.88d94724d8f2e6c186744a5584c6e59ecac869ec7ba15e9cb4cd628e8dc7066820b2481d8ee3b51ea8da323a7378068aa58c556a3720d32b7c20a051d088363a"
}
