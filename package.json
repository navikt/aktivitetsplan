{
  "name": "aktivitetsplan",
  "version": "2.0.0",
  "description": "Aktivitetsplan",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:gh-pages": "VITE_USE_HASH_ROUTER=true vite",
    "build:dev-ekstern": "vite build --mode=dev-ekstern --base=https://cdn.nav.no/dab/aktivitetsplan-dev-ekstern/build/",
    "build:dev-intern": "vite build --mode=dev-intern --base=https://cdn.nav.no/dab/aktivitetsplan-dev-intern/build/",
    "build:prod-ekstern": "vite build --mode=prod-ekstern --base=https://cdn.nav.no/dab/aktivitetsplan-prod-ekstern/build/",
    "build:prod-intern": "vite build --mode=prod-intern --base=https://cdn.nav.no/dab/aktivitetsplan-prod-intern/build/",
    "build": "cross-env VITE_USE_HASH_ROUTER=true vite build --mode=dev",
    "build:gh-pages": "VITE_USE_HASH_ROUTER=true vite build --mode=dev-ekstern --base=/aktivitetsplan/",
    "test": "NODE_OPTIONS=--no-webstorage vitest",
    "coverage": "NODE_OPTIONS=--no-webstorage vitest run --coverage",
    "lint": "oxlint",
    "lint-fix": "oxlint --fix",
    "typecheck": "tsc --noEmit",
    "format-all": "prettier --write 'src/'",
    "lint-staged": "lint-staged",
    "preview": "vite preview"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@nais/apm": "^0.5.0",
    "@navikt/aksel-icons": "^8.14.0",
    "@navikt/dab-spraksjekk": "^1.0.22",
    "@navikt/ds-css": "^8.14.0",
    "@navikt/ds-react": "^8.14.0",
    "@navikt/ds-tailwind": "^8.14.0",
    "@reduxjs/toolkit": "^2.12.0",
    "@vitejs/plugin-react": "^6.0.3",
    "classnames": "^2.5.1",
    "date-fns": "^4.4.0",
    "pdfjs-dist": "^5.7.284",
    "prop-types": "^15.8.1",
    "react": "^19.2.7",
    "react-collapse": "^5.1.1",
    "react-custom-scrollbars-2": "^4.5.0",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.81.0",
    "react-modal": "^3.16.3",
    "react-pdf": "^10.4.1",
    "react-redux": "^9.3.0",
    "react-router": "^8.2.0",
    "rebound": "^0.1.0",
    "redux": "^5.0.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.3",
    "vite-plugin-svgr": "^4.5.0",
    "vitest": "^4.1.10",
    "zod": "^3.25.76"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{js,ts,tsx,json,less,css,md}": [
      "prettier --write"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not ie <= 10",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@navikt/nav-dekoratoren-moduler": "^3.6.1",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.43",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/moment-duration-format": "^2.2.7",
    "@types/node": "^22.20.1",
    "@types/react": "^19.2.17",
    "@types/react-collapse": "^5.0.4",
    "@types/react-dom": "^19.1.0",
    "@types/react-modal": "^3.16.3",
    "@vitest/coverage-v8": "^4.1.10",
    "autoprefixer": "^10.5.2",
    "cross-env": "^10.1.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "import-sort-style-module": "^6.0.0",
    "jsdom": "^28.1.0",
    "less": "^4.6.7",
    "lint-staged": "^17.1.1",
    "msw": "^2.15.0",
    "oxlint": "^1.74.0",
    "postcss": "8.5.14",
    "prettier": "^3.9.4",
    "prettier-plugin-import-sort": "0.0.7",
    "tailwindcss": "^4.3.2",
    "vite-plugin-static-copy": "^4.1.1",
    "vite-plugin-tailwind-shadowdom": "^1.1.1"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/navikt/aktivitetsplan.git"
  },
  "importSort": {
    ".js, .jsx, .ts, .tsx": {
      "style": "module",
      "parser": "typescript"
    }
  },
  "msw": {
    "workerDirectory": "public"
  },
  "packageManager": "pnpm@11.15.1+sha512.81350b07e53c9538a02f1f2303b4290fa2d7be04e56e2a970c4cc4b417dc761de196edabd49d55c7dc9580db81007c44143e4e3d7e462b3000d23c255122d065"
}
